---
import PlaygroundLayout from "../components/PlaygroundLayout.astro"

// Import all .lus files from lus-examples
const exampleFiles = import.meta.glob("../../../lus-examples/*.lus", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>

// Filter to only playground-enabled examples and extract metadata
const examples: Array<{ name: string; content: string; unstable: boolean }> = []
for (const [path, content] of Object.entries(exampleFiles)) {
  // Check for "-- playground: true" in the first few lines
  if (content.includes("playground: true") || path.endsWith("hello.lus")) {
    const name = path.split("/").pop()!.replace(".lus", "")
    const unstable = content.includes("unstable: true")
    examples.push({ name, content, unstable })
  }
}

// Sort with hello first, then alphabetically
examples.sort((a, b) => {
  if (a.name === "hello") return -1
  if (b.name === "hello") return 1
  return a.name.localeCompare(b.name)
})

// Default to hello.lus
const defaultExample = examples.find((e) => e.name === "hello") || examples[0]
---

<PlaygroundLayout>
  <button
    slot="controls"
    id="run-btn"
    class="btn-run"
    disabled
    aria-busy="true"
    aria-keyshortcuts="Control+Enter Meta+Enter">Loading…</button
  >
  <button slot="controls" id="clear-btn" class="btn-clear">Clear</button>

  <Fragment slot="version">
    <select
      id="version-select"
      class="version-select"
      aria-label="Lus version"
      disabled
    >
      <option value="">Loading…</option>
    </select>
    <span id="version-tag"></span>
  </Fragment>

  <div class="pane editor-pane">
    <div class="pane-header">
      <h2>Code</h2>
      <select
        id="example-select"
        class="example-select"
        aria-label="Load example"
      >
        {
          examples.map((ex) => (
            <option
              value={ex.name}
              selected={ex.name === "hello"}
              data-unstable={ex.unstable}
            >
              {ex.name}
              {ex.unstable ? " (unstable)" : ""}
            </option>
          ))
        }
      </select>
    </div>
    <p class="sr-only">
      The editor traps Tab for indentation. Press Ctrl+M (Ctrl+Shift+M on
      macOS) to toggle Tab trapping.
    </p>
    <div id="code-editor">
      <p class="editor-loading">Loading editor…</p>
    </div>
  </div>
  <div class="pane output-pane">
    <div class="pane-header">
      <h2>Output</h2>
      <span class="kbd-hint" aria-hidden="true">⌘/Ctrl + ↵ to run</span>
    </div>
    <div
      class="output-content"
      id="output"
      role="log"
      aria-live="polite"
      aria-label="Program output"
      tabindex="0"
    >
    </div>
  </div>
</PlaygroundLayout>

<script
  define:vars={{
    examples: examples,
    defaultContent: defaultExample?.content || "",
  }}
>
  window.__lusExamples = examples
  window.__lusDefaultContent = defaultContent
</script>

<script>
  // @ts-nocheck
  import { init } from "modern-monaco"
  import { registerSyntax } from "modern-monaco/core"
  //@ts-ignore
  import { grammars } from "modern-monaco/shiki"
  import { getWasmReleases, loadLusWasm } from "../lib/wasm-loader"
  import type { WasmRelease, LusModule } from "../lib/wasm-loader"
  import lusGrammar from "../../../lus-textmate/lus.tmLanguage.json"

  // HACK: this sucks but it works
  grammars.push(lusGrammar as any)
  registerSyntax(lusGrammar as any)

  const editorContainer = document.getElementById("code-editor")!
  const output = document.getElementById("output")!
  const runBtn = document.getElementById("run-btn") as HTMLButtonElement
  const clearBtn = document.getElementById("clear-btn") as HTMLButtonElement
  const versionSelect = document.getElementById(
    "version-select",
  ) as HTMLSelectElement
  const versionTag = document.getElementById("version-tag")!
  const exampleSelect = document.getElementById(
    "example-select",
  ) as HTMLSelectElement

  const examples: Array<{ name: string; content: string }> =
    window.__lusExamples || []
  const defaultContent: string =
    window.__lusDefaultContent || 'print("Hello, Lus!")'

  // Pre-filled code travels in the hash as base64url (see playground-link.ts)
  const hashParams = new URLSearchParams(location.hash.slice(1))
  const hashVersion = hashParams.get("v")

  function decodeHashCode(): string | null {
    const raw = hashParams.get("code")
    if (!raw) return null
    try {
      const b64 = raw.replace(/-/g, "+").replace(/_/g, "/")
      const padded = b64 + "=".repeat((4 - (b64.length % 4)) % 4)
      const bytes = Uint8Array.from(atob(padded), (c) => c.charCodeAt(0))
      return new TextDecoder().decode(bytes)
    } catch {
      return null
    }
  }

  let currentModule: LusModule | null = null
  let releases: { stable: WasmRelease | null; unstable: WasmRelease | null }
  let editor: ReturnType<typeof monaco.editor.create>
  let monaco: Awaited<ReturnType<typeof init>>

  function appendOutput(
    text: string,
    type: "output" | "error" | "system" = "output",
  ) {
    const lines = text.split("\n")
    for (const lineText of lines) {
      const line = document.createElement("div")
      line.className = `output-line ${type}`
      line.textContent = lineText
      output.appendChild(line)
    }
    output.scrollTop = output.scrollHeight
  }

  function clearOutput() {
    output.innerHTML = ""
  }

  function setRunLoading(loading: boolean) {
    runBtn.disabled = loading
    runBtn.textContent = loading ? "Loading…" : "Run"
    if (loading) runBtn.setAttribute("aria-busy", "true")
    else runBtn.removeAttribute("aria-busy")
  }

  async function loadVersion(release: WasmRelease) {
    setRunLoading(true)
    clearOutput()
    appendOutput("Loading...", "system")

    try {
      if (currentModule) {
        currentModule.destroy()
        currentModule = null
      }

      currentModule = await loadLusWasm(release)
      clearOutput()
      setRunLoading(false)
      versionTag.textContent = release.isStable ? "stable" : "unstable"
      versionTag.className = release.isStable ? "tag stable" : "tag unstable"
    } catch (e) {
      runBtn.textContent = "Run"
      runBtn.removeAttribute("aria-busy")
      appendOutput(`Failed to load: ${e}`, "error")
    }
  }

  function runCode() {
    if (!currentModule || !editor) return

    const code = editor.getValue()
    if (!code.trim()) return

    try {
      const result = currentModule.execute(code)
      if (result && result.trim()) {
        appendOutput(result.trimEnd(), "output")
      } else {
        appendOutput("(no output)", "system")
      }
    } catch (e) {
      appendOutput(String(e), "error")
    }
  }

  function loadExample(name: string) {
    const example = examples.find((e) => e.name === name)
    if (example && editor) {
      editor.setValue(example.content)
    }
  }

  async function initEditor() {
    monaco = await init({
      defaultTheme: "github-dark-default",
    })

    editorContainer.textContent = ""
    editor = monaco.editor.create(editorContainer, {
      language: "lus",
      automaticLayout: true,
      minimap: { enabled: false },
      // zero-motion mandate: pin every animatable option even where the
      // current upstream default is off, so dependency bumps can't
      // silently reintroduce motion
      cursorBlinking: "solid",
      smoothScrolling: false,
      cursorSmoothCaretAnimation: "off",
      stickyScroll: { enabled: false },
      fontSize: 14,
      fontFamily:
        "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
      lineNumbers: "on",
      scrollBeyondLastLine: false,
      wordWrap: "on",
      tabSize: 2,
      padding: { top: 12, bottom: 12 },
    })

    const hashCode = decodeHashCode()
    const model = monaco.editor.createModel(hashCode ?? defaultContent, "lus")
    editor.setModel(model)

    if (hashCode !== null) {
      // reflect that the editor holds shared code, not the "hello" example
      const opt = document.createElement("option")
      opt.value = "__shared__"
      opt.textContent = "shared code"
      opt.disabled = true
      opt.selected = true
      exampleSelect.prepend(opt)
    }

    editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter, runCode)
  }

  async function initWasm() {
    try {
      appendOutput("Fetching releases…", "system")
      if (typeof SharedArrayBuffer === "undefined") {
        appendOutput(
          "SharedArrayBuffer not available. This is probably because you're running this site locally. This is a funny bug on both Firefox and Chromium:\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1984864\nhttps://issues.chromium.org/issues/386633375\n(let me know when this is fixed so I can remove this message)",
          "error",
        )
        runBtn.textContent = "Run"
        runBtn.removeAttribute("aria-busy")
        return
      }

      releases = await getWasmReleases()

      versionSelect.innerHTML = ""

      if (releases.stable) {
        const opt = document.createElement("option")
        opt.value = "stable"
        opt.textContent = `${releases.stable.version} (stable)`
        versionSelect.appendChild(opt)
      }

      if (releases.unstable) {
        const opt = document.createElement("option")
        opt.value = "unstable"
        opt.textContent = `${releases.unstable.version} (unstable)`
        versionSelect.appendChild(opt)
      }

      if (!releases.stable && !releases.unstable) {
        appendOutput("No WASM builds available.", "error")
        runBtn.textContent = "Run"
        runBtn.removeAttribute("aria-busy")
        return
      }

      versionSelect.disabled = false

      // Hash override first, then default to STABLE — the channel the
      // site recommends for most users
      const preferUnstable = hashVersion === "unstable"
      const defaultRelease = preferUnstable
        ? releases.unstable || releases.stable
        : releases.stable || releases.unstable
      if (defaultRelease) {
        versionSelect.value =
          defaultRelease === releases.unstable ? "unstable" : "stable"
        await loadVersion(defaultRelease)
        updateExampleAvailability(defaultRelease === releases.unstable)
      }
    } catch (e) {
      appendOutput(`Failed to fetch releases: ${e}`, "error")
      runBtn.textContent = "Run"
      runBtn.removeAttribute("aria-busy")
    }
  }

  runBtn.addEventListener("click", runCode)
  clearBtn.addEventListener("click", clearOutput)

  // run from anywhere on the page, not only while Monaco has focus
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Enter" && (ev.ctrlKey || ev.metaKey)) {
      ev.preventDefault()
      runCode()
    }
  })

  function updateExampleAvailability(isUnstable: boolean) {
    const options = exampleSelect.querySelectorAll("option")
    for (const opt of options) {
      const requiresUnstable = opt.dataset.unstable === "true"
      opt.disabled = requiresUnstable && !isUnstable
    }
    // If current selection is now disabled, switch to hello — but never
    // silently destroy code the user has edited
    const currentOpt = exampleSelect.querySelector(
      `option[value="${exampleSelect.value}"]`,
    ) as HTMLOptionElement
    if (currentOpt?.disabled && currentOpt.value !== "__shared__") {
      const prev = examples.find((e) => e.name === exampleSelect.value)
      exampleSelect.value = "hello"
      if (editor && prev && editor.getValue() === prev.content) {
        loadExample("hello")
      } else if (editor) {
        appendOutput(
          `"${prev?.name ?? "this example"}" needs the unstable build — your code was kept.`,
          "system",
        )
      }
    }
  }

  versionSelect.addEventListener("change", async () => {
    const selected = versionSelect.value
    const release = selected === "stable" ? releases.stable : releases.unstable
    if (release) {
      await loadVersion(release)
      updateExampleAvailability(selected === "unstable")
    }
  })

  exampleSelect.addEventListener("change", () => {
    loadExample(exampleSelect.value)
  })

  // Initialize both editor and WASM
  await Promise.all([initEditor(), initWasm()])
</script>

<style>
  @reference "../styles/global.css";

  /* dark chrome is flat (nothing to seat into) — pressed states are
     paint-only, per the zero-motion grammar */
  .btn-run {
    @apply px-3 py-1 font-bold text-sm cursor-pointer border-2 border-accent bg-accent text-ink select-none;

    &:hover {
      @apply bg-ink text-accent;
    }

    &:active {
      @apply bg-accent-soft border-accent-soft text-ink;
    }

    &:disabled {
      @apply bg-transparent text-accent/40 border-accent/30 cursor-not-allowed;
    }
  }

  .btn-clear {
    @apply px-3 py-1 font-bold text-sm cursor-pointer border-2 border-accent/40 bg-transparent text-accent-soft select-none hover:bg-accent/10 hover:border-accent/70;

    &:active {
      @apply bg-accent/20 border-accent;
    }
  }

  .version-select {
    @apply bg-ink text-tint border-2 border-accent/40 px-2 py-1 text-sm cursor-pointer;

    &:disabled {
      @apply text-tint/40 border-accent/20 cursor-not-allowed;
    }
  }

  .example-select {
    @apply bg-ink text-tint border-2 border-accent/40 px-2 py-0.5 text-xs cursor-pointer ml-2;
  }

  .tag {
    @apply px-2 py-0.5 text-xs font-bold uppercase;

    &:global(.stable) {
      @apply bg-accent text-ink;
    }

    &:global(.unstable) {
      @apply bg-accent-red text-ink-red;
    }
  }

  .pane {
    /* my-0 defeats the page-shell space-y child margin, which has no
       specificity but would otherwise knock the second pane out of
       line with the first */
    @apply flex-1 flex flex-col min-h-0 min-w-0 my-0;
  }

  .pane {
    @apply max-md:min-h-[35dvh];
  }

  .pane-header {
    @apply px-3 py-1.5 bg-ink text-accent text-sm font-bold uppercase tracking-wide border-b-2 border-accent/20 shrink-0 flex items-center;
  }

  .editor-pane {
    @apply border-b-2 md:border-b-0 md:border-r-2 border-accent/20;
  }

  .kbd-hint {
    @apply ml-auto font-mono text-xs normal-case tracking-normal text-accent/80 border border-accent/30 px-1.5 py-0.5;
  }

  #code-editor {
    @apply flex-1 w-full;

    .editor-loading {
      @apply p-3 text-sm text-accent/80 italic;
    }
  }

  /*
  ** Zero-motion kill-switch for modern-monaco: its runtime-injected VS
  ** Code stylesheet ships transitions (find widget slide, sticky scroll,
  ** widget fades) and @keyframes (codicon-spin, progress, fadeIn/Out).
  ** Nothing in the editor functionally depends on animation events, so
  ** everything becomes an instant repaint.
  */
  :global(#code-editor *),
  :global(#code-editor *::before),
  :global(#code-editor *::after),
  :global(.monaco-editor *),
  :global(.monaco-editor *::before),
  :global(.monaco-editor *::after) {
    transition: none !important;
    animation: none !important;
  }

  .output-content {
    @apply flex-1 overflow-y-auto p-3 font-mono text-sm;
  }

  :global(.output-line) {
    @apply whitespace-pre-wrap break-all text-tint;

    /* deliberate blank output lines keep their height */
    &:global(:empty)::after {
      content: "\00a0";
    }

    &:global(.system) {
      @apply text-accent italic;
    }

    &:global(.error) {
      @apply text-accent-red;
    }
  }
</style>
