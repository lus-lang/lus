---
import Layout from "../../components/Layout.astro"
import { getCollection, render } from "astro:content"
import { fmtDate } from "../../lib/date"

export async function getStaticPaths() {
  const news = await getCollection("news")
  return news.map((page) => ({
    params: { id: page.id },
    props: { page },
  }))
}

const { page } = Astro.props
const rendered = await render(page)
---

<Layout
  title={page.data.title}
  description={`Release notes for ${page.data.title}, published ${fmtDate(page.data.date)}.`}
>
  <main id="main">
    <section>
      <a href="/news" class="back-link">← Back to news</a>
      <article>
        <h1>{page.data.title}</h1>
        <p class="date">
          <time datetime={fmtDate(page.data.date)}>{fmtDate(page.data.date)}</time>
        </p>
        <rendered.Content />
      </article>
    </section>
  </main>
</Layout>

<style>
  @reference "../../styles/global.css";

  .back-link {
    @apply text-sm text-link font-normal no-underline hover:bg-accent-soft mb-3 inline-block;
  }

  article {
    @apply space-y-2 max-w-[80ch];

    .date {
      @apply text-sm text-ink/70 font-mono;
    }
  }
</style>
