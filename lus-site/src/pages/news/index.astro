---
import Layout from "../../components/Layout.astro"
import { getCollection } from "astro:content"
import { fmtDate } from "../../lib/date"

const news = await getCollection("news")
const sorted = news.toSorted(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)
---

<Layout
    title="News"
    description="Release notes and announcements from the Lus project."
>
    <main id="main">
        <section>
            <h1>News</h1>
            <p class="news-intro">
                Release notes and announcements from the Lus project.
            </p>
            <div class="news-list">
                {
                    sorted.map((item) => (
                        <a href={`/news/${item.id}`} class="news-row">
                            <time class="date" datetime={fmtDate(item.data.date)}>
                                {fmtDate(item.data.date)}
                            </time>
                            <span class="title">{item.data.title}</span>
                        </a>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>

<style>
    @reference "../../styles/global.css";

    .news-intro {
        @apply text-ink/80 mb-4;
    }

    /* strict reverse chronology: one framed column, no card grid */
    .news-list {
        @apply border-2 border-ink bg-paper divide-y-2 divide-ink max-w-3xl;
    }

    .news-row {
        @apply flex items-baseline gap-4 px-3 py-2 no-underline font-normal hover:bg-accent-soft;

        .date {
            @apply text-sm text-ink/70 font-mono shrink-0 w-28;
        }

        .title {
            @apply font-bold text-ink;
        }
    }
</style>
