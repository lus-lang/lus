---
import ManualLayout from "../../../components/ManualLayout.astro"
import ApiReference from "../../../components/ApiReference.astro"
import { getStdlibSections } from "../../../lib/api"

const sections = await getStdlibSections()
---

<ManualLayout title="API">
  <h1>API reference</h1>
  <p class="api-crossnote">
    The standard library, as available to Lus programs. Embedding Lus in C? See
    the <a href="/manual/api/c">C API reference</a>.
  </p>

  <ApiReference sections={sections} />

  <script is:inline>
    // stale deep links to C symbols predate the C API page split
    if (
      location.hash &&
      !document.getElementById(decodeURIComponent(location.hash.slice(1))) &&
      /^#(lua_|luaL_|lus_|LUA_|LUAL_)/.test(location.hash)
    ) {
      location.replace("/manual/api/c" + location.search + location.hash)
    }
  </script>
</ManualLayout>

<style>
  @reference "../../../styles/global.css";

  .api-crossnote {
    @apply text-ink/80 mb-4 max-w-3xl;
  }
</style>
