---
import { getCollection } from "astro:content"

import Layout from "../components/Layout.astro"
import Button from "../components/Button.astro"
import Card from "../components/Card.astro"
import ReleaseStrip from "../components/ReleaseStrip.astro"
import Icon from "../components/Icon.astro"

import { INSTALL_SH, WINDOWS_INSTALLER_URL } from "../lib/install"
import { fmtDate } from "../lib/date"

const allNews = await getCollection("news")
const news = allNews
  .toSorted((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)

// deep-links into the generated API reference (section ids are slugs of
// the section titles in lib/api.ts)
const stdlibMap = [
  {
    name: "base",
    desc: "core globals · JSON · CSV",
    href: "/manual/api#environment-functions",
  },
  {
    name: "string",
    desc: "patterns, formatting",
    href: "/manual/api#string-library",
  },
  {
    name: "table",
    desc: "manipulation, clone, sort",
    href: "/manual/api#table-library",
  },
  { name: "math", desc: "numerics", href: "/manual/api#math-library" },
  {
    name: "fs",
    desc: "filesystem & paths",
    href: "/manual/api#filesystem-library",
  },
  {
    name: "network",
    desc: "HTTP, TCP, UDP",
    href: "/manual/api#network-library",
  },
  {
    name: "worker",
    desc: "threads & messages",
    href: "/manual/api#worker-library",
  },
  {
    name: "vector",
    desc: "mutable byte buffers",
    href: "/manual/api#vector-library",
  },
  {
    name: "vector.archive",
    desc: "gzip, zstd, brotli, lz4",
    href: "/manual/api#archive-library",
  },
  { name: "io", desc: "streams & files", href: "/manual/api#io-library" },
  { name: "os", desc: "environment, time", href: "/manual/api#os-library" },
  { name: "utf8", desc: "Unicode helpers", href: "/manual/api#utf-8-library" },
  {
    name: "coroutine",
    desc: "cooperative threads",
    href: "/manual/api#coroutine-library",
  },
  {
    name: "debug",
    desc: "introspection, AST",
    href: "/manual/api#debug-library",
  },
  {
    name: "package",
    desc: "module loading",
    href: "/manual/api#package-library",
  },
  { name: "C API", desc: "embedding interface", href: "/manual/api/c" },
]
---

<Layout>
  <main id="main">
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-pitch">
          <h1 class="hero-title">A sovereign scripting language.</h1>
          <p class="hero-sub">
            Lus is a small, productive programming language designed to be
            picked up easily by programmers and put to good use right away.
          </p>
          <div class="hero-install">
            <div class="hero-install-meta">
              <span id="install-platform">linux x64</span>
              <a href="/manual/getting-started">other platforms</a>
              <a href="/manual/compiling">build from source</a>
            </div>
            <pre id="install-shell"><code>{INSTALL_SH}</code></pre>
            <p id="install-windows" hidden>
              <a class="install-win-btn" href={WINDOWS_INSTALLER_URL}>
                <Icon name="download" size={16} /> Download lus-setup.exe
              </a>
            </p>
          </div>
          <div class="hero-ctas">
            <Button href="/manual/getting-started">
              Get started <Icon name="arrow-right" size={16} />
            </Button>
            <Button variant="outline" href="/playground">
              <Icon name="terminal" size={16} /> Open the playground
            </Button>
          </div>
        </div>

        <aside class="hero-news">
          <Card variant="default" class="flex flex-col">
            <h2 slot="title">
              <Icon name="newspaper" size={16} class="inline-block" /> news
            </h2>
            <ul class="news-list">
              {
                news.map((item) => (
                  <li>
                    <time class="news-date" datetime={fmtDate(item.data.date)}>
                      {fmtDate(item.data.date)}
                    </time>
                    <a href={`/news/${item.id}`}>{item.data.title}</a>
                  </li>
                ))
              }
            </ul>
            <div slot="footer" class="px-3 pb-2 mt-auto">
              <a href="/news" class="text-sm">All news →</a>
            </div>
          </Card>
        </aside>
      </div>
    </section>

    <section>
      <h2>What's in Lus?</h2>
      <nav class="stdlib-map" aria-label="Standard library modules">
        {
          stdlibMap.map((mod) => (
            <a href={mod.href}>
              <span class="mod-name">{mod.name}</span>
              <span class="mod-desc">{mod.desc}</span>
            </a>
          ))
        }
      </nav>
    </section>

    <section>
      <h2>Releases</h2>
      <ReleaseStrip />
      <p class="release-note">
        Stable is for production; unstable is the latest features, continuously
        published. <a href="/manual/releases">About the channels.</a>
      </p>
    </section>
  </main>
</Layout>

<script is:inline>
  // adjust the server-rendered linux install for the visitor's platform:
  // macOS shares the same curl|sh line (label change only), Windows swaps
  // the shell line for the installer download; no-JS readers keep the
  // linux default plus the "other platforms" link
  const plat = (
    navigator.userAgentData?.platform ??
    navigator.platform ??
    ""
  ).toLowerCase()
  if (plat.includes("mac")) {
    document.getElementById("install-platform").textContent =
      "macos (apple silicon)"
  } else if (plat.includes("win")) {
    document.getElementById("install-platform").textContent = "windows x64"
    document.getElementById("install-shell").hidden = true
    document.getElementById("install-windows").hidden = false
  }
</script>

<style>
  @reference "../styles/global.css";

  .hero {
    .hero-grid {
      @apply flex flex-col gap-6 lg:grid lg:grid-cols-[1fr_minmax(280px,340px)] lg:gap-x-8 lg:items-start;
    }

    .hero-title {
      @apply text-4xl sm:text-5xl font-extrabold tracking-tighter max-w-3xl text-balance;
    }

    .hero-sub {
      @apply text-lg md:text-xl text-ink/80 max-w-2xl mt-3;
    }

    .hero-install {
      @apply max-w-2xl mt-3;

      .hero-install-meta {
        @apply flex flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-xs mb-1;

        #install-platform {
          @apply font-bold uppercase bg-accent-soft text-ink px-1.5 py-0.5;
        }

        a {
          @apply font-normal no-underline text-link hover:bg-accent-soft;
        }
      }

      pre {
        @apply my-0;

        code {
          @apply text-[13px];
        }
      }

      #install-windows {
        @apply my-0;

        .install-win-btn {
          @apply inline-flex items-center gap-2 border-2 border-ink bg-accent text-ink font-bold no-underline px-3 py-1.5 lus-shadow-sm lus-press;
        }
      }
    }

    .hero-ctas {
      @apply flex flex-wrap gap-3 mt-4;
    }

    .news-list {
      @apply list-none pl-0 space-y-1.5;

      li {
        @apply flex items-baseline gap-3;
      }

      .news-date {
        @apply text-xs text-ink/70 font-mono shrink-0;
      }

      a {
        @apply font-normal;
      }
    }
  }

  .stdlib-map {
    @apply grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2;

    a {
      @apply flex flex-col gap-0.5 border-2 border-ink bg-paper lus-shadow-sm lus-press p-2 no-underline hover:bg-accent-soft;

      .mod-name {
        @apply font-mono font-bold text-sm text-ink;
      }

      .mod-desc {
        @apply text-xs text-ink/70 font-normal;
      }
    }
  }

  .release-note {
    @apply text-sm text-ink/80;
  }
</style>
