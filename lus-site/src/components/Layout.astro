---
import { Image } from "astro:assets"
import "@fontsource-variable/atkinson-hyperlegible-next"
import "@fontsource-variable/atkinson-hyperlegible-next/wght-italic.css"
import "@fontsource-variable/atkinson-hyperlegible-mono"
import "@fontsource-variable/atkinson-hyperlegible-mono/wght-italic.css"

import "../styles/global.css"
import logo from "../assets/logo.svg"
import logoUnstable from "../assets/logo-unstable.svg"
import Icon from "./Icon.astro"

interface Props {
  title?: string
  description?: string
  unstable?: boolean
}

const currentLogo = Astro.props.unstable ? logoUnstable : logo
const path = Astro.url.pathname.replace(/\/$/, "") || "/"

const fullTitle = `Lus${Astro.props.title ? ` - ${Astro.props.title}` : ""}`
const description =
  Astro.props.description ??
  "Lus is a small, fast, and reliable programming language that is sovereign."
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://lus.dev",
)

const navLinks = [
  { href: "/playground", label: "playground", icon: "terminal" },
  { href: "/examples", label: "examples", icon: "code-xml" },
  { href: "/manual", label: "manual", icon: "book-open" },
  { href: "/news", label: "news", icon: "newspaper" },
]

function isActive(href: string) {
  return path === href || path.startsWith(href + "/")
}
---

<html lang="en" class:list={[{ unstable: Astro.props.unstable }]}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Louka Ménard Blondin" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://lus.dev/banner.png" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="418" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Lus" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://lus.dev/banner.png" />

    <title>{fullTitle}</title>
    <script src="../scripts/copy-code.ts"></script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header>
      <div class="header-inner">
        <a href="/" class="brand">
          <Image
            src={currentLogo}
            alt="Lus — home"
            class="lus-logo"
            width={32}
            height={32}
          />
          <span class="wordmark">lus</span>
        </a>

        <nav aria-label="Main">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[{ active: isActive(link.href) }]}
                aria-current={
                  path === link.href
                    ? "page"
                    : isActive(link.href)
                      ? "true"
                      : undefined
                }
              >
                <Icon name={link.icon} size={14} />
                {link.label}
              </a>
            ))
          }
          <a
            href="https://github.com/lus-lang/lus"
            target="_blank"
            rel="noopener"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
            github
          </a>
        </nav>
      </div>
    </header>
    {
      Astro.props.unstable && (
        <div class="unstable-banner">
          unstable-channel documentation — describes pre-release builds.{" "}
          <a href="/manual/releases">about channels</a>
        </div>
      )
    }
    <slot />
    <footer>
      <div class="footer-inner">
        <span class="footer-wordmark">Lus</span>
        <nav class="footer-links" aria-label="Footer">
          <a href="/manual">manual</a>
          <a href="/manual/api">api</a>
          <a href="/examples">examples</a>
          <a href="/playground">playground</a>
          <a href="/news">news</a>
          <a
            href="https://github.com/lus-lang/lus"
            target="_blank"
            rel="noopener">github</a
          >
          <a href="/manual/license">license</a>
          <a href="mailto:hello@louka.sh">contact</a>
        </nav>
        <p>
          © 2025–2026 <a href="https://louka.sh" target="_blank" rel="noopener"
            >Louka Ménard Blondin</a
          >. Licensed under the 0-clause BSD license.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  @reference "../styles/global.css";

  header {
    @apply bg-tint;

    .header-inner {
      @apply max-w-7xl mx-auto px-4 md:px-6 py-2 flex items-center gap-3;

      .brand {
        @apply flex items-center gap-2 no-underline shrink-0 hover:bg-transparent;

        .wordmark {
          @apply font-extrabold text-lg tracking-tight text-ink lowercase;
        }
      }

      .version-badge {
        @apply font-mono text-xs font-normal no-underline text-ink/70 border border-ink/20 bg-paper px-1.5 py-0.5 hover:bg-accent-soft hover:text-ink;
      }

      nav {
        @apply ml-auto flex flex-wrap items-center justify-end gap-x-2 gap-y-1;

        a {
          @apply flex items-center gap-1.5 text-sm font-bold lowercase no-underline text-ink/80 px-2 py-1 border-2 border-transparent hover:border-ink hover:bg-accent-soft hover:text-ink;

          &.active {
            @apply bg-accent border-ink lus-shadow-sm text-ink;
          }
        }
      }
    }
  }

  .unstable-banner {
    @apply bg-accent-red text-ink-red text-sm font-bold text-center px-4 py-1;

    a {
      @apply text-ink-red hover:bg-accent-soft-red;
    }
  }

  footer {
    @apply py-3 text-xs text-ink/80 bg-tint border-t-2 border-ink mt-auto;

    .footer-inner {
      @apply flex flex-wrap items-center justify-between px-4 md:px-6 gap-x-6 gap-y-1 max-w-7xl mx-auto;

      .footer-wordmark {
        @apply font-extrabold text-sm tracking-tight text-ink;
      }

      .footer-links {
        @apply flex flex-wrap items-center gap-x-2 gap-y-2;

        a {
          @apply font-bold lowercase no-underline text-ink/80 hover:bg-accent-soft hover:text-ink inline-block px-1 py-1;
        }
      }

      p {
        @apply text-right;

        a {
          @apply text-link;
        }
      }
    }
  }

  :global(html.unstable) {
    header {
      @apply bg-tint-red;

      .header-inner .brand .wordmark {
        @apply text-ink-red;
      }

      .header-inner .version-badge {
        @apply text-ink-red/70 border-ink-red/20 hover:bg-accent-soft-red hover:text-ink-red;
      }

      .header-inner nav a {
        @apply text-ink-red/80 hover:border-ink-red hover:bg-accent-soft-red hover:text-ink-red;

        &.active {
          @apply bg-accent-red border-ink-red lus-shadow-sm shadow-ink-red text-ink-red;
        }
      }
    }

    footer {
      @apply text-ink-red/80 bg-tint-red border-ink-red;

      .footer-inner {
        .footer-wordmark {
          @apply text-ink-red;
        }

        .footer-links a {
          @apply text-ink-red/80 hover:bg-accent-soft-red hover:text-ink-red;
        }

        p a {
          @apply text-link-red;
        }
      }
    }
  }
</style>
