---
interface Props {
  class?: string
  color?: "lime" | "red"
  variant?: "default" | "feature"
}

const { color = "lime", variant = "default" } = Astro.props
---

<div
  class:list={["card", Astro.props.class]}
  data-color={color}
  data-variant={variant}
>
  <slot name="eyebrow" />
  <slot name="title" />
  <div class="card-body"><slot /></div>
  <slot name="footer" />
</div>

<style>
  @reference "../styles/global.css";

  .card {
    @apply border-2 border-ink bg-paper text-ink;

    &[data-variant="default"] {
      @apply lus-shadow;
    }

    &[data-variant="feature"] {
      @apply lus-shadow-sm;
    }

    h2 {
      @apply font-bold text-base lowercase px-3 py-1.5 border-b-2 border-ink;
    }

    &[data-variant="default"] h2 {
      @apply bg-accent text-ink;
    }

    &[data-variant="feature"] h2 {
      @apply bg-tint text-ink;
    }

    .card-body {
      @apply p-3;
    }

    &[data-color="red"] {
      @apply border-ink-red shadow-ink-red text-ink-red;

      h2 {
        @apply border-ink-red;
      }

      &[data-variant="default"] h2 {
        @apply bg-accent-red text-ink-red;
      }

      &[data-variant="feature"] h2 {
        @apply bg-tint-red text-ink-red;
      }
    }
  }
</style>
