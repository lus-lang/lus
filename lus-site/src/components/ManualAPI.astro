---
import { render } from "astro:content"
import type { ApiSection, From } from "../lib/api"

interface Props {
  sections: ApiSection[]
}

const { sections } = Astro.props

type Rendered = {
  data: any
  from: From
  Content: any | null
}

const renderedSections: { title: string; id: string; entries: Rendered[] }[] =
  []
for (const section of sections) {
  const entries: Rendered[] = []
  for (const { entry, from } of section.entries) {
    const body = entry.body?.trim()
    if (body) {
      const { Content } = await render(entry)
      entries.push({ data: entry.data, from, Content })
    }
    else {
      entries.push({ data: entry.data, from, Content: null })
    }
  }
  renderedSections.push({ title: section.title, id: section.id, entries })
}

function fmtReturns(returns: string | { type: string; name?: string }[]) {
  if (typeof returns === "string") return returns
  return returns
    .map((r) => (r.name ? `${r.name}: ${r.type}` : r.type))
    .join(", ")
}

function haystack(d: any, from: From) {
  return [
    d.name,
    d.module ?? d.header ?? "",
    d.kind,
    from,
    d.fastcall ? "fastcall" : "",
  ]
    .join(" ")
    .toLowerCase()
}
---

<style>
  @reference "../styles/global.css";

  .api-entry {
    @apply mb-3 scroll-mt-14;
  }

  .api-section {
    @apply scroll-mt-12;
  }

  .api-heading {
    @apply flex items-baseline pb-1;
  }

  .api-name {
    @apply font-mono font-bold text-ink no-underline hover:bg-accent-soft;
  }

  .api-params {
    @apply font-mono text-sm text-link;
  }

  .api-returns {
    @apply font-mono text-sm text-ink/70;
  }

  .api-param-optional {
    @apply text-ink/70;
  }

  .api-param-type {
    @apply text-ink/70 text-xs;
  }

  .api-name-removed {
    @apply line-through text-neutral-600;
  }

  .api-signature {
    @apply font-mono text-sm bg-tint border-2 border-ink px-3 py-2 mb-1 whitespace-pre-wrap break-words;
  }

  .api-meta {
    @apply text-xs text-ink/70 font-mono mb-1;

    a {
      @apply font-mono;
    }
  }

  .api-body {
    @apply leading-snug;
  }

  .api-section-title {
    @apply text-xl font-bold mt-8 pb-1 mb-3 border-b-2 border-ink;
  }

  /* deep-link landing matches the global heading :target grammar */
  .api-entry:target .api-heading {
    background: var(--color-accent-soft);
  }
</style>

{
  renderedSections.map((section) => (
    <section class="api-section" id={section.id}>
      <h2 class="api-section-title">{section.title}</h2>
      {section.entries.map((entry) => {
        const d = entry.data
        const from = entry.from
        const isFunction = d.kind === "function"
        const isCapi = !!d.header
        const hasCSignature = isCapi && d.signature
        const removed = from === "removed"

        return (
          <div class="api-entry" id={d.name} data-api={haystack(d, from)}>
            <div class="api-heading">
              {from === "lus" && <span class="api-badge api-badge-lus">lus</span>}
              {from === "lus-unstable" && (
                <span class="api-badge api-badge-unstable">unstable</span>
              )}
              {from === "deprecated" && (
                <span class="api-badge api-badge-deprecated">deprecated</span>
              )}
              {from === "removed" && (
                <span class="api-badge api-badge-removed">removed</span>
              )}
              {from === "lua" && <span class="api-badge api-badge-lua">lua</span>}
              {d.fastcall && (
                <span class="api-badge api-badge-fastcall">fastcall</span>
              )}
              {isFunction && !hasCSignature && !removed ? (
                <Fragment>
                  <a class="api-name" href={`#${d.name}`}>{d.name}</a>
                  <!-- prettier-ignore -->
                  <span class="api-params">({d.params
                      ? d.params.map((p: any, i: number) => (
                          <Fragment>
                            {i > 0 && ", "}
                            {p.optional ? (
                              <span class="api-param-optional">[{p.name}{p.type && p.type !== "any" ? (
                                  <span class="api-param-type">: {p.type}</span>
                                ) : ""}]</span>
                            ) : (
                              <span>{p.name}{p.type && p.type !== "any" ? (
                                  <span class="api-param-type">: {p.type}</span>
                                ) : ""}</span>
                            )}
                          </Fragment>
                        ))
                      : ""}{d.vararg ? (d.params?.length ? ", ..." : "...") : ""})</span>
                  {d.returns && (
                    <span class="api-returns">&nbsp;→ {fmtReturns(d.returns)}</span>
                  )}
                </Fragment>
              ) : (
                <a
                  class:list={["api-name", { "api-name-removed": removed }]}
                  href={`#${d.name}`}
                >
                  {d.name}
                </a>
              )}
            </div>

            {!removed && hasCSignature && (
              <div class="api-signature">{d.signature.replace(/^"|"$/g, "")}</div>
            )}

            {!removed && (
              <div class="api-meta">
                since {d.since}
                {d.kind === "constant" && d.value !== undefined
                  ? ` · value: ${d.value}${d.type ? ` (${d.type})` : ""}`
                  : ""}
                {(d.kind === "variable" || d.kind === "type") &&
                !d.signature &&
                d.type
                  ? ` · type: ${d.type}`
                  : ""}
                {from === "deprecated" && d.deprecated_by ? (
                  <Fragment>
                    {" · use "}
                    <a href={`#${d.deprecated_by}`}>{d.deprecated_by}</a>
                  </Fragment>
                ) : (
                  ""
                )}
                {d.removed_in ? ` · removed in ${d.removed_in}` : ""}
              </div>
            )}

            {entry.Content && (
              <div class="api-body">
                <entry.Content />
              </div>
            )}
          </div>
        )
      })}
    </section>
  ))
}
