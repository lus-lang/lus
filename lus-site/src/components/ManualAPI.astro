---
import { getCollection, render } from "astro:content"

const stdlibEntries = await getCollection("stdlib")
const capiEntries = await getCollection("capi")
const allEntries = [...stdlibEntries, ...capiEntries]

const rendered: { data: any; Content: any | null }[] = []
for (const entry of allEntries) {
  const body = entry.body?.trim()
  if (body) {
    const { Content } = await render(entry)
    rendered.push({ data: entry.data, Content })
  } else {
    rendered.push({ data: entry.data, Content: null })
  }
}

rendered.sort((a, b) => {
  const aIsStdlib = !!a.data.module
  const bIsStdlib = !!b.data.module
  if (aIsStdlib !== bIsStdlib) return aIsStdlib ? -1 : 1
  return a.data.name.localeCompare(b.data.name)
})

type Section = { title: string; entries: typeof rendered }
const sections: Section[] = []

const sectionOrder = [
  { title: "Environment Functions", filter: (d: any) => d.module === "base" },
  { title: "Table Library", filter: (d: any) => d.module === "table" },
  { title: "String Library", filter: (d: any) => d.module === "string" },
  { title: "Math Library", filter: (d: any) => d.module === "math" },
  { title: "IO Library", filter: (d: any) => d.module === "io" },
  { title: "OS Library", filter: (d: any) => d.module === "os" },
  { title: "Debug Library", filter: (d: any) => d.module === "debug" },
  { title: "Coroutine Library", filter: (d: any) => d.module === "coroutine" },
  { title: "Package Library", filter: (d: any) => d.module === "package" },
  { title: "UTF-8 Library", filter: (d: any) => d.module === "utf8" },
  {
    title: "Filesystem Library",
    filter: (d: any) => d.module === "fs" || d.module === "fs.path",
  },
  {
    title: "Network Library",
    filter: (d: any) =>
      d.module === "network" ||
      d.module === "network.tcp" ||
      d.module === "network.udp",
  },
  { title: "JSON Library", filter: (d: any) => d.module === "json" },
  { title: "Vector Library", filter: (d: any) => d.module === "vector" },
  {
    title: "Worker Library",
    filter: (d: any) => d.module === "worker" && !d.header,
  },
  {
    title: "Permission System — C API",
    filter: (d: any) => d.header === "lpledge.h",
  },
  {
    title: "Worker System — C API",
    filter: (d: any) => d.header === "lworkerlib.h",
  },
  { title: "Library Openers", filter: (d: any) => d.header === "lualib.h" },
  { title: "Core C API", filter: (d: any) => d.header === "lua.h" },
  { title: "Auxiliary C API", filter: (d: any) => d.header === "lauxlib.h" },
]

const used = new Set<string>()
for (const sec of sectionOrder) {
  const entries = rendered.filter(
    (e) => !used.has(e.data.name) && sec.filter(e.data),
  )
  for (const e of entries) used.add(e.data.name)
  if (entries.length > 0) {
    sections.push({ title: sec.title, entries })
  }
}
const remaining = rendered.filter((e) => !used.has(e.data.name))
if (remaining.length > 0) {
  sections.push({ title: "Other", entries: remaining })
}
---

<style>
  @reference "../styles/global.css";

  .api-entry {
    @apply mb-4;
  }

  .api-heading {
    @apply flex items-baseline pb-1;
  }

  .api-name {
    @apply font-mono font-bold text-lime-950;
  }

  .api-params {
    @apply font-mono text-sm text-lime-800;
  }

  .api-param-optional {
    @apply text-lime-600;
  }

  .api-param-type {
    @apply text-lime-600 text-xs;
  }

  .api-badge {
    @apply text-[10px] font-mono font-bold uppercase px-1.5 py-0.5 mr-2 rounded-sm shrink-0;
  }

  .api-badge-lua {
    @apply bg-sky-200 text-sky-600;
  }

  .api-badge-lus {
    @apply bg-lime-200 text-lime-800;
  }

  .api-badge-deprecated {
    @apply bg-yellow-200 text-yellow-800;
  }

  .api-badge-unstable {
    @apply bg-red-200 text-red-800;
  }

  .api-signature {
    @apply font-mono text-sm bg-white border border-lime-300 px-3 py-2 mb-2 overflow-x-auto whitespace-pre;
  }

  .api-meta {
    @apply text-xs text-lime-700 font-mono mb-2;
  }

  .api-body {
    @apply text-justify leading-tight;
  }

  .api-section-title {
    @apply text-xl font-bold mt-12 pb-1 mb-4 border-b;
  }
</style>

{
  sections.map((section) => (
    <Fragment>
      <h2 class="api-section-title">{section.title}</h2>
      {section.entries.map((entry) => {
        const d = entry.data
        const isFunction = d.kind === "function"
        const isCapi = !!d.header
        const hasCSignature = isCapi && d.signature
        const badge =
          d.origin === "lus"
            ? d.stability === "unstable"
              ? "unstable"
              : d.stability === "deprecated"
                ? "deprecated"
                : "lus"
            : d.stability === "deprecated"
              ? "deprecated"
              : "lua"

        return (
          <div class="api-entry" id={d.name}>
            <div class="api-heading">
              {badge === "lus" && (
                <span class="api-badge api-badge-lus">lus</span>
              )}
              {badge === "unstable" && (
                <span class="api-badge api-badge-unstable">unstable</span>
              )}
              {badge === "deprecated" && (
                <span class="api-badge api-badge-deprecated">deprecated</span>
              )}
              {badge === "lua" && (
                <span class="api-badge api-badge-lua">lua</span>
              )}
              {isFunction && !hasCSignature ? (
                <Fragment>
                  <span class="api-name">{d.name}</span>
                  <!-- prettier-ignore -->
                  <span class="api-params">({d.params
                      ? d.params.map((p: any, i: number) => (
                          <Fragment>
                            {i > 0 && ", "}
                            {p.optional ? (
                              <span class="api-param-optional">[{p.name}{p.type && p.type !== "any" ? (
                                  <span class="api-param-type">: {p.type}</span>
                                ) : ""}]</span>
                            ) : (
                              <span>{p.name}{p.type && p.type !== "any" ? (
                                  <span class="api-param-type">: {p.type}</span>
                                ) : ""}</span>
                            )}
                          </Fragment>
                        ))
                      : ""}{d.vararg ? (d.params?.length ? ", ..." : "...") : ""})</span>
                </Fragment>
              ) : (
                <span class="api-name">{d.name}</span>
              )}
            </div>

            {hasCSignature && (
              <div class="api-signature">
                {d.signature.replace(/^"|"$/g, "")}
              </div>
            )}

            {d.kind === "constant" && d.value !== undefined && (
              <div class="api-meta">
                Value: {d.value}
                {d.type ? ` (${d.type})` : ""}
              </div>
            )}

            {d.kind === "variable" && d.type && (
              <div class="api-meta">Type: {d.type}</div>
            )}

            {d.kind === "type" && !d.signature && d.type && (
              <div class="api-meta">Type: {d.type}</div>
            )}

            {entry.Content && (
              <div class="api-body">
                <entry.Content />
              </div>
            )}
          </div>
        )
      })}
    </Fragment>
  ))
}
