---
import Layout from "./Layout.astro"
import { getCollection } from "astro:content"
// @ts-ignore
import icons from "virtual:lucide-icons"

interface Props {
  title: string
  unstable?: boolean
}
const { title, unstable } = Astro.props

const manual = await getCollection("manual")

const currentPath = Astro.url.pathname.replace(/\/$/, "")
---

<Layout title={title} unstable={unstable}>
  <main>
    <section class="flex flex-col-reverse lg:flex-row gap-8">
      <aside>
        <nav class="sidebar">
          {
            manual
              .filter((page) => !page.data.acquis)
              .toSorted((a, b) => a.data.order - b.data.order)
              .map((page) => (
                <a
                  class:list={[
                    "sidebar-link",
                    { active: currentPath === `/manual/${page.id}` },
                  ]}
                  href={`/manual/${page.id}`}
                >
                  {page.data.icon && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      {icons[page.data.icon].map(([tag, attrs]: any) => {
                        const El = tag as any
                        return <El {...attrs} />
                      })}
                    </svg>
                  )}
                  {page.data.title}
                </a>
              ))
          }
          <a
            class:list={[
              "sidebar-link",
              { active: currentPath === "/manual/api" },
            ]}
            href="/manual/api"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              {
                icons["library"].map(([tag, attrs]: any) => {
                  const El = tag as any
                  return <El {...attrs} />
                })
              }
            </svg>
            API
          </a>
        </nav>
      </aside>
      <article class="flex-1 min-w-0">
        <slot />
      </article>
    </section>
  </main>
</Layout>

<style>
  @reference "../styles/global.css";

  :global(hr) {
    @apply my-4 text-lime-800;
  }

  article {
    @apply space-y-2;
  }

  aside {
    @apply min-w-48 w-1/6 sticky top-8 self-start;

    .sidebar-link {
      @apply flex items-center gap-1.5 lg:-ml-1 py-0.5 no-underline text-lime-800 font-normal hover:underline;

      svg {
        @apply p-1 box-content;
      }

      &.active {
        @apply text-lime-900 font-bold;

        svg {
          @apply text-lime-200;
          background: linear-gradient(135deg, #a3e635, #4d7c0f);
        }
      }
    }
  }

  :global(html.unstable) aside .sidebar-link {
    @apply text-red-800;

    &.active {
      @apply text-red-900;

      svg {
        @apply text-red-200;
        background: linear-gradient(135deg, #fca5a5, #b91c1c);
      }
    }
  }
</style>
