global print, require, assert, type, string, table, utf8, math, error, ipairs, pairs, tostring, pledge

pledge("load", "fs:read=./lus-tests/*", "seal")

local framework = require("lus-tests.framework")
local tests = framework.new("utf8")

tests:it("utf8 char single", function()
    assert(utf8.char(65) == "A")
    assert(utf8.char(0x20AC) == "€")
    assert(utf8.char(0x1F600) == "😀")
end)

tests:it("utf8 char multiple", function()
    assert(utf8.char(65, 66, 67) == "ABC")
    assert(utf8.char(0x20AC, 0x20AC) == "€€")
end)

tests:it("utf8 codepoint", function()
    assert(utf8.codepoint("A") == 65)
    assert(utf8.codepoint("€") == 0x20AC)
    
    -- multiple codepoints
    local a, b, c = utf8.codepoint("ABC", 1, 3)
    assert(a == 65 and b == 66 and c == 67)
end)

tests:it("utf8 len", function()
    assert(utf8.len("A") == 1)
    assert(utf8.len("€") == 1)
    assert(utf8.len("abc") == 3)
    assert(utf8.len("£") == 1)
    assert(utf8.len("") == 0)
    assert(utf8.len("hello") == 5)
    assert(utf8.len("héllo") == 5)
end)

tests:it("utf8 offset", function()
    local s = "A€B"
    assert(utf8.offset(s, 1) == 1)
    assert(utf8.offset(s, 2) == 2)
    assert(utf8.offset(s, 3) == 5)
    assert(utf8.offset(s, 4) == 6)
end)

tests:it("utf8 offset negative", function()
    local s = "ABC"
    assert(utf8.offset(s, -1) == 3)
    assert(utf8.offset(s, -2) == 2)
    assert(utf8.offset(s, -3) == 1)
end)

tests:it("utf8 codes iterator", function()
    local s = "A€"
    local t = {}
    for p, c in utf8.codes(s) do
        table.insert(t, {p=p, c=c})
    end
    assert(#t == 2)
    assert(t[1].p == 1 and t[1].c == 65)
    assert(t[2].p == 2 and t[2].c == 0x20AC)
end)

tests:it("invalid sequences", function()
    assert(utf8.len("\xFF") == nil)
    local ok = catch utf8.codepoint("\xFF")
    assert(not ok)
end)

tests:it("utf8.charpattern", function()
    assert(utf8.charpattern)
    local s = "hello"
    local count = 0
    for _ in string.gmatch(s, utf8.charpattern) do
        count = count + 1
    end
    assert(count == 5)
end)

tests:it("4-byte character round-trip", function()
    local s = utf8.char(0x1F600)
    tests:assert_equal(utf8.codepoint(s), 0x1F600)
end)

tests:it("boundary codepoint round-trips", function()
    local codepoints = {0x007F, 0x0080, 0x07FF, 0x0800, 0xFFFF, 0x10000, 0x10FFFF}
    for _, cp in ipairs(codepoints) do
        local s = utf8.char(cp)
        tests:assert_equal(utf8.codepoint(s), cp)
    end
end)

tests:it("utf8.len with byte range", function()
    local euro = utf8.char(0x20AC)  -- 3-byte char
    local s = "A" .. euro .. "B"    -- 1 + 3 + 1 = 5 bytes, 3 chars
    tests:assert_equal(utf8.len(s), 3)
    tests:assert_equal(utf8.len(s, 2, 4), 1)  -- just the euro sign
    tests:assert_equal(utf8.len(s, 1, 1), 1)  -- just A
    tests:assert_equal(utf8.len(s, 5, 5), 1)  -- just B
end)

tests:it("utf8.offset negative n with multi-byte", function()
    local euro = utf8.char(0x20AC)  -- 3 bytes
    local s = euro .. "AB"          -- 3 + 1 + 1 = 5 bytes, 3 chars
    tests:assert_equal(utf8.offset(s, -1), 5)  -- B starts at byte 5
    tests:assert_equal(utf8.offset(s, -2), 4)  -- A starts at byte 4
    tests:assert_equal(utf8.offset(s, -3), 1)  -- euro starts at byte 1
end)

tests:it("rejects overlong encoding", function()
    local overlong = "\xC0\xAF"  -- overlong encoding of U+002F
    local len, err = utf8.len(overlong)
    tests:assert_nil(len)
end)

tests:it("codes iterates mixed multi-byte correctly", function()
    local s = "A" .. utf8.char(0xE9) .. utf8.char(0x20AC) .. utf8.char(0x1F600)
    local cps = {}
    for _, c in utf8.codes(s) do
        cps[#cps + 1] = c
    end
    tests:assert_equal(#cps, 4)
    tests:assert_equal(cps[1], 65)      -- A
    tests:assert_equal(cps[2], 0xE9)    -- e accent
    tests:assert_equal(cps[3], 0x20AC)  -- euro
    tests:assert_equal(cps[4], 0x1F600) -- emoji
end)

tests:finish()

