        table = {
            transpose = function(t)
                custom_called = true
                return {{99}}
            end,
        },
    }, {__index = _G})
    local chunk = load("return table.transpose({{1,2},{3,4}})", "test", "t", env)
    local result = chunk()
    assert(result[1][1] == 99)
    assert(custom_called)
end)

