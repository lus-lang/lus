-- ==== Correctness: table.stdev() ====
tests:it("table.stdev correctness", function()
    -- Population stdev of {2, 4, 4, 4, 5, 5, 7, 9}
    local r = table.stdev({2, 4, 4, 4, 5, 5, 7, 9})
    assert(math.abs(r - 2.0) < 0.001, "expected ~2.0, got " .. tostring(r))
    -- Single element: stdev is 0
    assert(table.stdev({5}) == 0.0)
    -- Empty returns NaN
    local nan = table.stdev({})
    assert(nan ~= nan)
end)

-- ==== Environment tainting: table.stdev ====
