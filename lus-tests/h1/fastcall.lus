-- ==== Correctness: table.sum() ====
tests:it("table.sum correctness", function()
    assert(table.sum({1, 2, 3, 4, 5}) == 15.0)
    assert(table.sum({1.5, 2.5}) == 4.0)
    assert(table.sum({}) == 0.0)
    assert(table.sum({10}) == 10.0)
end)

