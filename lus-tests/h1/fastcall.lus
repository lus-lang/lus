global print, require, string, math, assert, type, rawequal, rawget, rawset, rawlen, _G, table, tostring, tonumber, select, error, pledge, setmetatable, getmetatable, collectgarbage, load, vector, utf8, coroutine

pledge("load", "fs:read=./lus-tests/*", "seal")

local framework = require("lus-tests.framework")
local tests = framework.new("fastcall")

-- ==== Correctness: type() ====
tests:it("type correctness", function()
    assert(type(nil) == "nil")
    assert(type(true) == "boolean")
    assert(type(false) == "boolean")
    assert(type(42) == "number")
    assert(type(3.14) == "number")
    assert(type("hello") == "string")
    assert(type({}) == "table")
    assert(type(print) == "function")
    assert(type(type) == "function")
end)

-- ==== Correctness: rawlen() ====
tests:it("rawlen correctness", function()
    assert(rawlen({1, 2, 3}) == 3)
    assert(rawlen({}) == 0)
    assert(rawlen("hello") == 5)
    assert(rawlen("") == 0)
    assert(rawlen({1, 2, 3, 4, 5}) == 5)
end)

-- ==== Correctness: rawget() ====
tests:it("rawget correctness", function()
    local t = {a = 1, b = 2, [3] = "three"}
    assert(rawget(t, "a") == 1)
    assert(rawget(t, "b") == 2)
    assert(rawget(t, 3) == "three")
    assert(rawget(t, "c") == nil)
    assert(rawget(t, 999) == nil)
end)

-- ==== Correctness: rawset() ====
tests:it("rawset correctness", function()
    local t = {}
    rawset(t, "x", 10)
    assert(t.x == 10)
    rawset(t, 1, "one")
    assert(t[1] == "one")
    rawset(t, "x", nil)
    assert(t.x == nil)
end)

-- ==== Correctness: rawequal() ====
tests:it("rawequal correctness", function()
    assert(rawequal(1, 1) == true)
    assert(rawequal(1, 2) == false)
    assert(rawequal("a", "a") == true)
    assert(rawequal("a", "b") == false)
    assert(rawequal(nil, nil) == true)
    assert(rawequal(nil, false) == false)
    local t = {}
    assert(rawequal(t, t) == true)
    assert(rawequal({}, {}) == false)
end)

-- ==== Correctness: math.abs() ====
tests:it("math.abs correctness", function()
    assert(math.abs(5) == 5)
    assert(math.abs(-5) == 5)
    assert(math.abs(0) == 0)
    assert(math.abs(3.14) == 3.14)
    assert(math.abs(-3.14) == 3.14)
    assert(math.abs(0.0) == 0.0)
    -- Edge case: mininteger (abs of mininteger wraps in two's complement)
    local result = math.abs(math.mininteger)
    assert(type(result) == "number")
end)

-- ==== Correctness: math.max() ====
tests:it("math.max correctness", function()
    assert(math.max(1, 2) == 2)
    assert(math.max(2, 1) == 2)
    assert(math.max(-1, -2) == -1)
    assert(math.max(0, 0) == 0)
    -- Integer-integer
    assert(math.max(100, 200) == 200)
    -- Float-float
    assert(math.max(1.5, 2.5) == 2.5)
    -- Mixed int-float
    assert(math.max(1, 2.5) == 2.5)
    assert(math.max(3, 2.5) == 3.0)
end)

-- ==== Correctness: math.min() ====
tests:it("math.min correctness", function()
    assert(math.min(1, 2) == 1)
    assert(math.min(2, 1) == 1)
    assert(math.min(-1, -2) == -2)
    assert(math.min(0, 0) == 0)
    -- Float-float
    assert(math.min(1.5, 2.5) == 1.5)
    -- Mixed int-float
    assert(math.min(1, 2.5) == 1.0)
    assert(math.min(3, 2.5) == 2.5)
end)

-- ==== Correctness: string.len() ====
tests:it("string.len correctness", function()
    assert(string.len("hello") == 5)
    assert(string.len("") == 0)
    assert(string.len("a") == 1)
    assert(string.len("hello world") == 11)
end)

-- ==== NaN handling for math.max/min ====
tests:it("math.max/min NaN", function()
    local nan = 0/0
    -- NaN comparisons are false, so behavior depends on order
    local r1 = math.max(nan, 1)
    local r2 = math.max(1, nan)
    -- Both should produce consistent results with the C function
    assert(type(r1) == "number")
    assert(type(r2) == "number")
end)

-- ==== Environment tainting: type ====
tests:it("tainted type fallback", function()
    local original_type = type
    local custom_called = false
    -- Rebind type in a new environment
    local env = setmetatable({
        type = function(x)
            custom_called = true
            return "custom"
        end,
    }, {__index = _G})
    local chunk = load("return type(42)", "test", "t", env)
    local result = chunk()
    assert(result == "custom", "expected custom, got " .. tostring(result))
    assert(custom_called)

    -- Verify original still works
    assert(original_type(42) == "number")
end)

-- ==== Environment tainting: math.max ====
tests:it("tainted math.max fallback", function()
    local custom_called = false
    local env = setmetatable({
        math = {
            max = function(a, b)
                custom_called = true
                return a + b
            end,
        },
    }, {__index = _G})
    local chunk = load("return math.max(3, 5)", "test", "t", env)
    local result = chunk()
    assert(result == 8, "expected 8, got " .. tostring(result))
    assert(custom_called)
end)

-- ==== Argument count: math.max with 3 args (should NOT be fastcall'd) ====
tests:it("math.max 3 args normal call", function()
    -- math.max with 3 args should use normal OP_CALL (not fastcall)
    local r = math.max(1, 2, 3)
    assert(r == 3)
end)

-- ==== Argument count: type with 0 args ====
tests:it("type 0 args error", function()
    local ok, err = catch(function() return type() end)()
    assert(not ok, "type() with 0 args should error")
end)

-- ==== Fastcall inside catch ====
tests:it("fastcall in catch", function()
    local ok, val = catch(function() return type(42) end)()
    assert(ok == true)
    assert(val == "number")
end)

-- ==== Fastcall inside loops ====
tests:it("fastcall in for loop", function()
    local results = {}
    for i = 1, 5 do
        results[i] = math.abs(-i)
    end
    assert(results[1] == 1)
    assert(results[5] == 5)
end)

tests:it("fastcall in while loop", function()
    local i = -5
    local sum = 0
    while i <= 5 do
        sum = sum + math.abs(i)
        i = i + 1
    end
    assert(sum == 30) -- |(-5)|+|(-4)|+...+|5| = 2*(1+2+3+4+5) = 30
end)

-- ==== Multi-return context ====
tests:it("fastcall multi-return context", function()
    -- When type() is used as last arg in a call, C may be changed
    -- from 2 to 0 (multi-return). The VM should fall back to slow path.
    local function capture(...)
        return select("#", ...), ...
    end
    local n, v = capture(type(42))
    assert(n == 1)
    assert(v == "number")
end)

-- ==== Fastcall with local _ENV rebinding ====
tests:it("local ENV rebinding fallback", function()
    -- When _ENV is rebound locally, the compiler should still
    -- emit OP_CALL (not OP_FASTCALL) since upvalue 0 won't be _ENV
    local custom_type_called = false
    local _ENV = setmetatable({
        type = function(x)
            custom_type_called = true
            return "rebound"
        end,
    }, {__index = _G})
    local result = type(42)
    assert(result == "rebound", "expected rebound, got " .. tostring(result))
    assert(custom_type_called)
end)

-- ==== Rawset GC correctness ====
tests:it("rawset GC barrier", function()
    -- Stress test rawset with string values to exercise GC barrier
    local t = {}
    for i = 1, 1000 do
        rawset(t, "key" .. i, "value" .. i)
    end
    -- Force a GC cycle
    collectgarbage("collect")
    -- Verify values survived
    assert(rawget(t, "key1") == "value1")
    assert(rawget(t, "key1000") == "value1000")
end)

-- ==== rawget/rawset bypass metamethods ====
tests:it("rawget bypasses __index", function()
    local mt = {__index = function(t, k) return "meta" end}
    local t = setmetatable({}, mt)
    assert(t.x == "meta") -- through metamethod
    assert(rawget(t, "x") == nil) -- bypasses metamethod
end)

tests:it("rawset bypasses __newindex", function()
    local blocked = false
    local mt = {__newindex = function(t, k, v) blocked = true end}
    local t = setmetatable({}, mt)
    rawset(t, "x", 42)
    assert(not blocked) -- metamethod not called
    assert(rawget(t, "x") == 42)
end)

-- ==== string.len type error fallback ====
tests:it("string.len type error fallback", function()
    local ok, err = catch(function() return string.len({}) end)()
    assert(not ok, "string.len({}) should error")
end)

-- ==== Correctness: string.trim() ====
tests:it("string.trim correctness", function()
    assert(string.trim("  hello  ") == "hello")
    assert(string.trim("\t\nhello\r\n") == "hello")
    assert(string.trim("hello") == "hello")
    assert(string.trim("   ") == "")
    assert(string.trim("") == "")
    assert(string.trim("  a  b  ") == "a  b")
end)

