-- ==== Correctness: string.split() ====
tests:it("string.split correctness", function()
    local r = string.split("a,b,c", ",")
    assert(#r == 3)
    assert(r[1] == "a" and r[2] == "b" and r[3] == "c")
    -- Empty delimiter: split into characters
    r = string.split("abc", "")
    assert(#r == 3)
    assert(r[1] == "a" and r[2] == "b" and r[3] == "c")
    -- Trailing delimiter
    r = string.split("a,b,", ",")
    assert(#r == 3)
    assert(r[3] == "")
    -- Empty string
    r = string.split("", ",")
    assert(#r == 1 and r[1] == "")
    -- Multi-char delimiter
    r = string.split("a::b::c", "::")
    assert(#r == 3 and r[1] == "a" and r[2] == "b" and r[3] == "c")
end)

-- ==== Environment tainting: string.split ====
tests:it("tainted string.split fallback", function()
    local custom_called = false
    local env = setmetatable({
        string = {
            split = function(s, d)
                custom_called = true
                return {"custom"}
            end,
        },
    }, {__index = _G})
    local chunk = load('return string.split("a,b", ",")', "test", "t", env)
    local result = chunk()
    assert(result[1] == "custom")
    assert(custom_called)
end)

-- ==== string.split type error fallback ====
tests:it("string.split type error fallback", function()
    local ok, err = catch(function() return string.split({}, ",") end)()
    assert(not ok, "string.split({}, ',') should error")
end)

-- ==== Correctness: string.join() ====
tests:it("string.join correctness", function()
    assert(string.join({"a", "b", "c"}, ",") == "a,b,c")
    assert(string.join({"hello"}, "-") == "hello")
    assert(string.join({}, ",") == "")
    assert(string.join({"a", "b"}, "") == "ab")
    assert(string.join({"x", "y", "z"}, "::") == "x::y::z")
end)

-- ==== Environment tainting: string.join ====
tests:it("tainted string.join fallback", function()
    local custom_called = false
    local env = setmetatable({
        string = {
            join = function(t, d)
                custom_called = true
                return "custom"
            end,
        },
    }, {__index = _G})
    local chunk = load('return string.join({"a"}, ",")', "test", "t", env)
    local result = chunk()
    assert(result == "custom")
    assert(custom_called)
end)

-- ==== string.join type error fallback ====
tests:it("string.join type error fallback", function()
    local ok, err = catch(function() return string.join("notatable", ",") end)()
    assert(not ok, "string.join('notatable', ',') should error")
end)

-- ==== Correctness: string.sub() fastcall ====
tests:it("string.sub correctness", function()
    assert(string.sub("hello", 2, 4) == "ell")
    assert(string.sub("hello", 1, 5) == "hello")
    assert(string.sub("hello", 1, 1) == "h")
    assert(string.sub("hello", -3, -1) == "llo")
    assert(string.sub("hello", -3, 4) == "ll")
    assert(string.sub("hello", 3, 2) == "")  -- start > end
    assert(string.sub("hello", 1, 100) == "hello")  -- j beyond length
    assert(string.sub("hello", -100, 2) == "he")  -- i before start
    assert(string.sub("", 1, 1) == "")  -- empty string
end)

-- ==== Correctness: string.byte() fastcall ====
tests:it("string.byte correctness", function()
    assert(string.byte("A", 1) == 65)
    assert(string.byte("hello", 2) == string.byte("e", 1))
    assert(string.byte("hello", 5) == string.byte("o", 1))
    assert(string.byte("hello", -1) == string.byte("o", 1))  -- negative index
    assert(string.byte("hello", 6) == nil)  -- out of bounds
    assert(string.byte("hello", 0) == string.byte("h", 1))  -- 0 maps to 1 via posrelatI
    assert(string.byte("a", 1) == 97)
end)

-- ==== Correctness: string.char() fastcall ====
tests:it("string.char correctness", function()
    assert(string.char(65) == "A")
    assert(string.char(97) == "a")
    assert(string.char(0) == "\0")
    assert(string.char(255) == "\xFF")
    assert(string.char(48) == "0")
end)

-- ==== Correctness: string.lower() fastcall ====
tests:it("string.lower correctness", function()
    assert(string.lower("HELLO") == "hello")
    assert(string.lower("Hello World") == "hello world")
    assert(string.lower("already lower") == "already lower")
    assert(string.lower("123!@#") == "123!@#")
    assert(string.lower("") == "")
end)

-- ==== Correctness: string.upper() fastcall ====
tests:it("string.upper correctness", function()
    assert(string.upper("hello") == "HELLO")
    assert(string.upper("Hello World") == "HELLO WORLD")
    assert(string.upper("ALREADY UPPER") == "ALREADY UPPER")
    assert(string.upper("123!@#") == "123!@#")
    assert(string.upper("") == "")
end)

-- ==== Correctness: string.reverse() fastcall ====
tests:it("string.reverse correctness", function()
    assert(string.reverse("hello") == "olleh")
    assert(string.reverse("a") == "a")
    assert(string.reverse("") == "")
    assert(string.reverse("ab") == "ba")
    assert(string.reverse("12345") == "54321")
end)

