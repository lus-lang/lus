    tests:assert_fastcall(function(s) return utf8.codepoint(s) end, FC.UTF8_CODEPOINT)
end)

-- ==== Negative emission cases ====
tests:describe("OP_FASTCALL non-emission")

tests:it("does not emit OP_FASTCALL for math.max with 3 args", function()
    tests:assert_no_fastcall(function() return math.max(1, 2, 3) end, FC.MATH_MAX)
end)

tests:it("does not emit OP_FASTCALL for math.min with 3 args", function()
    tests:assert_no_fastcall(function() return math.min(1, 2, 3) end, FC.MATH_MIN)
end)

tests:it("does not emit OP_FASTCALL for table.stdev with 2 args", function()
    tests:assert_no_fastcall(function() return table.stdev({1}, true) end, FC.TABLE_STDEV)
end)

tests:it("does not emit OP_FASTCALL for type with 0 args", function()
    tests:assert_no_fastcall(function() return type() end, FC.TYPE)
end)

tests:it("does not emit OP_FASTCALL for tonumber with 2 args", function()
    tests:assert_no_fastcall(function(x) return tonumber(x, 16) end, FC.TONUMBER)
end)

tests:it("does not emit OP_FASTCALL for math.log with 2 args", function()
    tests:assert_no_fastcall(function(x) return math.log(x, 10) end, FC.MATH_LOG)
end)

tests:it("does not emit OP_FASTCALL when _ENV is rebound", function()
    local chunk = load("local e = _ENV; return function() local _ENV = e; return type(42) end")
    local fn = chunk()
    -- When _ENV is locally rebound, upvalue 0 is not _ENV,
    -- so the compiler should NOT emit OP_FASTCALL
    tests:assert_no_fastcall(fn, FC.TYPE)
end)

-- ==== Edge cases ====
tests:describe("edge cases")

tests:it("setmetatable blocked by __metatable", function()
    local mt = {__metatable = "locked"}
    local t = setmetatable({}, mt)
    local ok, err = catch setmetatable(t, {})
    tests:assert_true(not ok)
end)

tests:it("rawset returns the table", function()
    local t = {}
    local result = rawset(t, "key", "value")
    tests:assert_equal(result, t)
end)

tests:it("fastcall in coroutine", function()
    local co = coroutine.wrap(function()
        coroutine.yield(type(42))
        coroutine.yield(math.abs(-5))
        return string.len("hello")
    end)
    tests:assert_equal(co(), "number")
    tests:assert_equal(co(), 5)
    tests:assert_equal(co(), 5)
end)

tests:it("math.abs type error", function()
    tests:assert_throws(function() return math.abs("hello") end)
end)

tests:it("table.reshape rejects overflow dimensions", function()
    local t = {1, 2, 3, 4}
    tests:assert_throws(function()
        table.reshape(t, math.maxinteger, math.maxinteger)
    end)
end)

tests:finish()
