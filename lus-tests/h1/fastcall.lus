-- ==== Correctness: table.mean() ====
tests:it("table.mean correctness", function()
    assert(table.mean({2, 4, 6}) == 4.0)
    assert(table.mean({10}) == 10.0)
    -- Empty table returns NaN
    local r = table.mean({})
    assert(r ~= r) -- NaN
end)

