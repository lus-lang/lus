    assert(custom_called)
end)

-- ==== table.stdev 2-arg (sample) falls back ====
tests:it("table.stdev sample fallback", function()
    -- 2-arg variant should NOT be fastcalled (nargs mismatch)
    local r = table.stdev({2, 4, 4, 4, 5, 5, 7, 9}, true)
    assert(type(r) == "number")
end)

-- ==== Correctness: table.transpose() ====
tests:it("table.transpose correctness", function()
    local m = {{1, 2, 3}, {4, 5, 6}}
    local r = table.transpose(m)
    assert(#r == 3)
    assert(r[1][1] == 1 and r[1][2] == 4)
    assert(r[2][1] == 2 and r[2][2] == 5)
    assert(r[3][1] == 3 and r[3][2] == 6)
    -- Empty matrix
    r = table.transpose({})
    assert(#r == 0)
end)

-- ==== Environment tainting: table.transpose ====
