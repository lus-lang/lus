    local custom_called = false
    local env = setmetatable({
        utf8 = {
            len = function(s)
                custom_called = true
                return 999
            end,
        },
    }, {__index = _G})
    local chunk = load('return utf8.len("hello")', "test", "t", env)
    local result = chunk()
    assert(result == 999, "expected 999, got " .. tostring(result))
