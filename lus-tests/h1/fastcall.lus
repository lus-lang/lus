    assert(string.rtrim("  hello  ") == "  hello")
    assert(string.rtrim("hello\t\n") == "hello")
    assert(string.rtrim("hello") == "hello")
    assert(string.rtrim("   ") == "")
    assert(string.rtrim("") == "")
end)

