end)

tests:it("emits OP_FASTCALL for string.upper()", function()
    tests:assert_fastcall(function(s) return string.upper(s) end, FC.STRING_UPPER)
end)

tests:it("emits OP_FASTCALL for string.reverse()", function()
    tests:assert_fastcall(function(s) return string.reverse(s) end, FC.STRING_REVERSE)
end)

tests:it("emits OP_FASTCALL for table.sum()", function()
    tests:assert_fastcall(function() return table.sum({1}) end, FC.TABLE_SUM)
end)

tests:it("emits OP_FASTCALL for table.mean()", function()
    tests:assert_fastcall(function() return table.mean({1}) end, FC.TABLE_MEAN)
