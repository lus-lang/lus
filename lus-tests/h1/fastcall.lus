end)

-- ==== Correctness: assert() ====
tests:it("assert correctness", function()
    assert(assert(42) == 42)
    assert(assert("hello") == "hello")
    assert(assert(true) == true)
    local ok, err = catch(function() assert(false) end)()
    assert(not ok)
    local ok2, err2 = catch(function() assert(nil, "msg") end)()
    assert(not ok2)
end)

-- ==== Correctness: getmetatable() ====
tests:it("getmetatable correctness", function()
    local mt = {__index = function() end}
    local t = setmetatable({}, mt)
    assert(getmetatable(t) == mt)
    assert(getmetatable({}) == nil)
    assert(getmetatable("hello") ~= nil) -- strings have metatable
    -- __metatable field
    local mt2 = {__metatable = "protected"}
    local t2 = setmetatable({}, mt2)
    assert(getmetatable(t2) == "protected")
end)

-- ==== Correctness: setmetatable() ====
tests:it("setmetatable correctness", function()
    local t = {}
    local mt = {}
    assert(setmetatable(t, mt) == t)
    assert(getmetatable(t) == mt)
    setmetatable(t, nil)
    assert(getmetatable(t) == nil)
end)

-- ==== Correctness: tonumber() ====
tests:it("tonumber correctness", function()
    assert(tonumber(42) == 42)
    assert(tonumber(3.14) == 3.14)
    assert(tonumber("123") == 123)
    assert(tonumber("3.14") == 3.14)
    assert(tonumber("hello") == nil)
    assert(tonumber(nil) == nil)
    assert(tonumber(true) == nil)
end)

-- ==== Correctness: tostring() ====
tests:it("tostring correctness", function()
    assert(tostring(42) == "42")
    assert(tostring(3.14) == "3.14")
    assert(tostring("hello") == "hello")
    assert(tostring(nil) == "nil")
    assert(tostring(true) == "true")
    assert(tostring(false) == "false")
end)

-- ==== Correctness: math.ceil/floor ====
tests:it("math.ceil/floor correctness", function()
    assert(math.ceil(3.2) == 4)
    assert(math.ceil(3.0) == 3)
    assert(math.ceil(-3.2) == -3)
    assert(math.ceil(5) == 5)
    assert(math.floor(3.7) == 3)
    assert(math.floor(3.0) == 3)
    assert(math.floor(-3.2) == -4)
    assert(math.floor(5) == 5)
end)

-- ==== Correctness: math.sqrt ====
tests:it("math.sqrt correctness", function()
    assert(math.sqrt(4) == 2.0)
    assert(math.sqrt(9) == 3.0)
    assert(math.sqrt(0) == 0.0)
    assert(math.abs(math.sqrt(2) - 1.4142135623730951) < 1e-10)
end)

-- ==== Correctness: math trig ====
tests:it("math trig correctness", function()
    assert(math.abs(math.sin(0)) < 1e-10)
    assert(math.abs(math.cos(0) - 1.0) < 1e-10)
    assert(math.abs(math.tan(0)) < 1e-10)
    assert(math.abs(math.asin(0)) < 1e-10)
    assert(math.abs(math.acos(1.0)) < 1e-10)
    assert(math.abs(math.atan(0)) < 1e-10)
end)

-- ==== Correctness: math.exp/log ====
tests:it("math.exp/log correctness", function()
    assert(math.abs(math.exp(0) - 1.0) < 1e-10)
    assert(math.abs(math.exp(1) - 2.718281828459045) < 1e-10)
    assert(math.abs(math.log(1) - 0.0) < 1e-10)
    assert(math.abs(math.log(math.exp(1)) - 1.0) < 1e-10)
end)

-- ==== Correctness: math.deg/rad ====
tests:it("math.deg/rad correctness", function()
    assert(math.abs(math.deg(math.pi) - 180.0) < 1e-6)
    assert(math.abs(math.rad(180) - math.pi) < 1e-10)
    assert(math.deg(0) == 0.0)
    assert(math.rad(0) == 0.0)
end)

-- ==== Correctness: math.fmod ====
tests:it("math.fmod correctness", function()
    assert(math.fmod(7, 3) == 1)
    assert(math.fmod(7.5, 3.0) == 1.5)
    assert(math.fmod(-7, 3) == -1)
    assert(math.fmod(10, 5) == 0)
end)

-- ==== Correctness: math.ult ====
tests:it("math.ult correctness", function()
    assert(math.ult(1, 2) == true)
    assert(math.ult(2, 1) == false)
    assert(math.ult(0, 1) == true)
    -- -1 as unsigned is very large
    assert(math.ult(1, -1) == true)
    assert(math.ult(-1, 1) == false)
end)

-- ==== Correctness: math.tointeger ====
tests:it("math.tointeger correctness", function()
    assert(math.tointeger(5) == 5)
    assert(math.tointeger(5.0) == 5)
    assert(math.tointeger(5.5) == nil)
    assert(math.tointeger("hello") == nil)
end)

-- ==== Correctness: math.type ====
tests:it("math.type correctness", function()
    assert(math.type(42) == "integer")
    assert(math.type(3.14) == "float")
    assert(math.type("hello") == nil)
    assert(math.type(nil) == nil)
end)

-- ==== Correctness: math.ldexp ====
tests:it("math.ldexp correctness", function()
    assert(math.ldexp(1, 10) == 1024.0)
    assert(math.ldexp(0.5, 1) == 1.0)
    assert(math.ldexp(3, 0) == 3.0)
end)

-- ==== Correctness: vector operations ====
tests:it("vector.create/size/resize correctness", function()
    local v = vector.create(10)
    assert(vector.size(v) == 10)
    vector.resize(v, 20)
    assert(vector.size(v) == 20)
    vector.resize(v, 5)
    assert(vector.size(v) == 5)
end)

tests:it("vector.clone correctness", function()
    local v = vector.create(8)
    local c = vector.clone(v)
    assert(vector.size(c) == 8)
    assert(v ~= c) -- different objects
end)

-- ==== Correctness: utf8 operations ====
tests:it("utf8.len correctness", function()
    assert(utf8.len("hello") == 5)
    assert(utf8.len("") == 0)
    assert(utf8.len("café") == 4)
end)

tests:it("utf8.codepoint correctness", function()
    assert(utf8.codepoint("A") == 65)
    assert(utf8.codepoint("é") == 233)
end)

tests:it("utf8.char correctness", function()
    assert(utf8.char(65) == "A")
    assert(utf8.char(233) == "é")
end)

tests:it("utf8.offset correctness", function()
    local s, e = utf8.offset("hello", 1)
    assert(s == 1 and e == 1)
    s, e = utf8.offset("hello", 2)
    assert(s == 2 and e == 2)
    s, e = utf8.offset("café", 4)
    assert(s == 4 and e == 5) -- é is 2 bytes
end)

-- ==== Emission verification: OP_FASTCALL detection via string.dump ====
tests:describe("OP_FASTCALL emission")

local FC = framework.FC

tests:it("emits OP_FASTCALL for type()", function()
    tests:assert_fastcall(function() return type(42) end, FC.TYPE)
end)

tests:it("emits OP_FASTCALL for rawlen()", function()
    tests:assert_fastcall(function() return rawlen({}) end, FC.RAWLEN)
end)

tests:it("emits OP_FASTCALL for rawget()", function()
    tests:assert_fastcall(function() local t = {} return rawget(t, "k") end, FC.RAWGET)
end)

tests:it("emits OP_FASTCALL for rawset()", function()
    tests:assert_fastcall(function() local t = {} rawset(t, "k", 1) end, FC.RAWSET)
end)

tests:it("emits OP_FASTCALL for rawequal()", function()
    tests:assert_fastcall(function() return rawequal(1, 2) end, FC.RAWEQUAL)
end)

tests:it("emits OP_FASTCALL for math.abs()", function()
    tests:assert_fastcall(function() return math.abs(-1) end, FC.MATH_ABS)
end)

tests:it("emits OP_FASTCALL for math.max()", function()
    tests:assert_fastcall(function() return math.max(1, 2) end, FC.MATH_MAX)
end)

tests:it("emits OP_FASTCALL for math.min()", function()
    tests:assert_fastcall(function() return math.min(1, 2) end, FC.MATH_MIN)
end)

tests:it("emits OP_FASTCALL for string.len()", function()
    tests:assert_fastcall(function() return string.len("hi") end, FC.STRING_LEN)
end)

tests:it("emits OP_FASTCALL for string.trim()", function()
    tests:assert_fastcall(function() return string.trim(" x ") end, FC.STRING_TRIM)
end)

tests:it("emits OP_FASTCALL for string.ltrim()", function()
    tests:assert_fastcall(function() return string.ltrim(" x") end, FC.STRING_LTRIM)
end)

tests:it("emits OP_FASTCALL for string.rtrim()", function()
    tests:assert_fastcall(function() return string.rtrim("x ") end, FC.STRING_RTRIM)
end)

tests:it("emits OP_FASTCALL for string.split()", function()
    tests:assert_fastcall(function() return string.split("a,b", ",") end, FC.STRING_SPLIT)
end)

tests:it("emits OP_FASTCALL for string.join()", function()
    tests:assert_fastcall(function() return string.join({}, ",") end, FC.STRING_JOIN)
end)

tests:it("emits OP_FASTCALL for string.sub()", function()
    tests:assert_fastcall(function(s) return string.sub(s, 1, 3) end, FC.STRING_SUB)
end)

tests:it("emits OP_FASTCALL for string.byte()", function()
    tests:assert_fastcall(function(s) return string.byte(s, 1) end, FC.STRING_BYTE)
end)

tests:it("emits OP_FASTCALL for string.char()", function()
    tests:assert_fastcall(function(n) return string.char(n) end, FC.STRING_CHAR)
end)

tests:it("emits OP_FASTCALL for string.lower()", function()
