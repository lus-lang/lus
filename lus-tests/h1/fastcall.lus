end)

-- ==== Correctness: table.reshape() ====
tests:it("table.reshape correctness", function()
    local r = table.reshape({1, 2, 3, 4, 5, 6}, 2, 3)
    assert(#r == 2)
    assert(r[1][1] == 1 and r[1][2] == 2 and r[1][3] == 3)
    assert(r[2][1] == 4 and r[2][2] == 5 and r[2][3] == 6)
    -- 1x4
    r = table.reshape({10, 20, 30, 40}, 1, 4)
    assert(#r == 1 and #r[1] == 4)
    assert(r[1][4] == 40)
end)

-- ==== Environment tainting: table.reshape ====
tests:it("tainted table.reshape fallback", function()
    local custom_called = false
    local env = setmetatable({
        table = {
            reshape = function(t, r, c)
                custom_called = true
                return {{0}}
            end,
        },
    }, {__index = _G})
    local chunk = load("return table.reshape({1,2,3,4}, 2, 2)", "test", "t", env)
    local result = chunk()
    assert(result[1][1] == 0)
    assert(custom_called)
end)

-- ==== table.reshape dimension mismatch fallback ====
tests:it("table.reshape dimension error", function()
    local ok, err = catch(function() return table.reshape({1, 2, 3}, 2, 2) end)()
    assert(not ok, "reshape with mismatched dimensions should error")
end)

-- ==== Environment tainting: math.abs ====
tests:it("tainted math.abs fallback", function()
    local custom_called = false
    local env = setmetatable({
        math = {
            abs = function(x)
                custom_called = true
                return 999
            end,
        },
    }, {__index = _G})
    local chunk = load("return math.abs(-5)", "test", "t", env)
    local result = chunk()
    assert(result == 999, "expected 999, got " .. tostring(result))
    assert(custom_called)
end)

-- ==== Environment tainting: assert ====
tests:it("tainted assert fallback", function()
    local custom_called = false
    local env = setmetatable({
        assert = function(v)
            custom_called = true
            return "custom"
        end,
    }, {__index = _G})
    local chunk = load("return assert(true)", "test", "t", env)
    local result = chunk()
    assert(result == "custom", "expected custom, got " .. tostring(result))
    assert(custom_called)
end)

-- ==== Environment tainting: tonumber ====
tests:it("tainted tonumber fallback", function()
    local custom_called = false
    local env = setmetatable({
        tonumber = function(x)
            custom_called = true
            return 999
        end,
    }, {__index = _G})
    local chunk = load('return tonumber("42")', "test", "t", env)
    local result = chunk()
    assert(result == 999, "expected 999, got " .. tostring(result))
    assert(custom_called)
end)

