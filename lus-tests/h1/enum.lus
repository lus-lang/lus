--[[
    Test suite for the enum feature in Lus.
    
    Syntax:
    - local e = enum name1, name2, ... end
    - Enums are symbols: only equal to themselves
    - Index by name: e.name1, e.name2
    - Index by number: e[1], e[2] (1-based)
    - tonumber(e.name1) returns the 1-based index
    - Ordering comparison by index: e.name1 < e.name2
]]

global assert, type, tonumber, os, require, pledge

pledge("load", "fs:read=./lus-tests/*", "seal")

local framework = require("lus-tests.framework")
local tests = framework.new("enum")

tests:it("basic enum declaration", function()
    local e = enum
        apple, orange, celery
    end
    assert(e ~= nil)
end)

tests:it("enum equals first value", function()
    local e = enum
        apple, orange, celery
    end
    assert(e == e.apple)
end)

tests:it("different values not equal", function()
    local e = enum
        apple, orange, celery
    end
    assert(e.apple ~= e.orange)
    assert(e.orange ~= e.celery)
    assert(e.apple ~= e.celery)
end)

tests:it("different enums never equal", function()
    local e1 = enum a, b, c end
    local e2 = enum a, b, c end
    assert(e1.a ~= e2.a)
    assert(e1.b ~= e2.b)
end)

tests:it("same enum values are equal", function()
    local e = enum x, y, z end
    assert(e.x == e.x)
    assert(e.y == e.y)
    assert(e[1] == e.x)
    assert(e[2] == e.y)
end)

tests:it("tonumber returns 1-based index", function()
    local e = enum
        first, second, third, fourth
    end
    assert(tonumber(e.first) == 1)
    assert(tonumber(e.second) == 2)
    assert(tonumber(e.third) == 3)
    assert(tonumber(e.fourth) == 4)
end)

tests:it("index by number", function()
    local e = enum a, b, c, d end
    assert(e[1] == e.a)
    assert(e[2] == e.b)
    assert(e[3] == e.c)
    assert(e[4] == e.d)
end)

tests:it("chained indexing", function()
    local e = enum x, y, z end
    assert(e.x.y == e.y)
    assert(e.x.z == e.z)
    assert(e.y.x == e.x)
    assert(e.z.y.x == e.x)
end)

tests:it("chained numeric indexing", function()
    local e = enum a, b, c end
    assert(e[1][2] == e.b)
    assert(e[3][1] == e.a)
end)

tests:it("less than comparison", function()
    local e = enum first, second, third end
    assert(e.first < e.second)
    assert(e.second < e.third)
    assert(e.first < e.third)
end)

tests:it("less than or equal comparison", function()
    local e = enum a, b, c end
    assert(e.a <= e.a)
    assert(e.a <= e.b)
    assert(e.b <= e.c)
end)

tests:it("greater than comparison", function()
    local e = enum x, y, z end
    assert(e.z > e.y)
    assert(e.y > e.x)
    assert(e.z > e.x)
end)

tests:it("greater than or equal comparison", function()
    local e = enum a, b, c end
    assert(e.c >= e.c)
    assert(e.c >= e.b)
    assert(e.b >= e.a)
end)

tests:it("type returns enum", function()
    local e = enum val end
    assert(type(e) == "enum")
    assert(type(e.val) == "enum")
end)

tests:it("type of indexed value", function()
    local e = enum a, b, c end
    assert(type(e[1]) == "enum")
    assert(type(e.b) == "enum")
end)

tests:it("single value enum", function()
    local e = enum only end
    assert(e == e.only)
    assert(tonumber(e.only) == 1)
end)

tests:it("enum in table", function()
    local e = enum red, green, blue end
    local t = { color = e.green }
    assert(t.color == e.green)
    assert(t.color ~= e.red)
end)

tests:it("enum as function argument", function()
    local e = enum on, off end
    local function check(val)
        return val == e.on
    end
    assert(check(e.on) == true)
    assert(check(e.off) == false)
end)

tests:it("enum as function return", function()
    local e = enum success, failure end
    local function getStatus()
        return e.success
    end
    assert(getStatus() == e.success)
end)

tests:it("cross-enum index comparison", function()
    local e1 = enum a, b, c end
    local e2 = enum x, y, z end
    -- Same positions but different enums
    assert(tonumber(e1.a) == tonumber(e2.x))
    assert(tonumber(e1.b) == tonumber(e2.y))
    -- But values themselves are not equal
    assert(e1.a ~= e2.x)
end)

tests:it("cross-root less-than raises error", function()
    local e1 = enum a, b end
    local e2 = enum x, y end
    local ok, err = catch (e1.a < e2.x)
    assert(ok == false)
    assert(type(err) == "string")
end)

tests:it("cross-root less-equal raises error", function()
    local e1 = enum a, b end
    local e2 = enum x, y end
    local ok, err = catch (e1.a <= e2.x)
    assert(ok == false)
    assert(type(err) == "string")
end)

tests:it("cross-root greater-than raises error", function()
    local e1 = enum a, b end
    local e2 = enum x, y end
    local ok, err = catch (e1.b > e2.x)
    assert(ok == false)
end)

tests:it("cross-root greater-equal raises error", function()
    local e1 = enum a, b end
    local e2 = enum x, y end
    local ok, err = catch (e1.b >= e2.x)
    assert(ok == false)
end)

tests:it("cross-root equality returns false", function()
    local e1 = enum a, b, c end
    local e2 = enum a, b, c end
    -- Same names/positions but different roots: never equal
    assert(e1.a ~= e2.a)
    assert(e1.b ~= e2.b)
    assert(e1.c ~= e2.c)
    assert(not (e1.a == e2.a))
end)

tests:it("single-member enum ordering", function()
    local e = enum only end
    assert(e.only <= e.only)
    assert(not (e.only < e.only))
end)

tests:it("first and last member ordering", function()
    local e = enum a, b, c, d, e end
    assert(e.a < e.e)
    assert(e.e > e.a)
    assert(e.a <= e.a)
    assert(e.e >= e.e)
end)

tests:it("enum with many values", function()
    local e = enum
        v1, v2, v3, v4, v5,
        v6, v7, v8, v9, v10
    end
    assert(tonumber(e.v1) == 1)
    assert(tonumber(e.v10) == 10)
    assert(e[5] == e.v5)
end)

tests:finish()
