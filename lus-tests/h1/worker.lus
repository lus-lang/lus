-- Worker library tests (Acquis 11)
global worker, pledge, print, require, table, type, tostring

-- Grant permissions needed for workers and framework
pledge("load")
pledge("fs")

local tests = require("lus-tests/framework")
local t = tests.new("worker")

t:describe("worker.create")

t:it("creates a worker and returns a handle", function()
  local w = worker.create("lus-tests/h1/worker/counter.lus")
  t:assert_true(w ~= nil, "worker.create should return handle")
  t:assert_equal(type(w), "userdata", "worker should be userdata")
end)

t:describe("worker.status")

t:it("returns 'running' for active worker", function()
  local w = worker.create("lus-tests/h1/worker/counter.lus")
  local status = worker.status(w)
  -- Status could be running or dead depending on timing
  t:assert_true(status == "running" or status == "dead", 
    "status should be 'running' or 'dead'")
end)

t:describe("worker.message and worker.receive")

t:it("receives messages from worker", function()
  local w = worker.create("lus-tests/h1/worker/counter.lus")
  
  -- Collect all messages
  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end
  
  t:assert_equal(#messages, 5, "should receive 5 messages")
  t:assert_equal(messages[1], 1, "first message should be 1")
  t:assert_equal(messages[5], 5, "last message should be 5")
end)

t:describe("worker.send and worker.peek")

t:it("sends messages to worker and receives responses", function()
  local w = worker.create("lus-tests/h1/worker/processor.lus")
  
  -- Send messages
  worker.send(w, "hello")
  worker.send(w, "world")
  worker.send(w, "STOP")
  
  -- Receive responses
  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end
  
  t:assert_equal(#messages, 3, "should receive 3 responses")
  t:assert_equal(messages[1], "GOT: hello", "first response")
  t:assert_equal(messages[2], "GOT: world", "second response")
  t:assert_equal(messages[3], "STOPPED", "stop confirmation")
end)

t:describe("serialization of types")

t:it("serializes integer messages", function()
  local w = worker.create("lus-tests/h1/worker/counter.lus")
  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end
  for i = 1, 5 do
    t:assert_equal(type(messages[i]), "number", "message should be number")
    t:assert_equal(messages[i], i, "message value should match")
  end
end)

t:it("serializes table messages", function()
  local w = worker.create("lus-tests/h1/worker/table.lus")
  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end

  t:assert_equal(#messages, 3, "should receive 3 table messages")

  -- Array table
  t:assert_equal(type(messages[1]), "table")
  t:assert_equal(messages[1][1], 1)
  t:assert_equal(messages[1][2], 2)
  t:assert_equal(messages[1][3], 3)

  -- Key-value table
  t:assert_equal(messages[2].key, "value")
  t:assert_equal(messages[2].num, 42)

  -- Nested table
  t:assert_equal(type(messages[3].nested), "table")
  t:assert_equal(messages[3].nested.a, 1)
  t:assert_equal(messages[3].nested.b[1], 2)
  t:assert_equal(messages[3].nested.b[2], 3)
end)

t:describe("message ordering")

t:it("delivers messages in FIFO order", function()
  local w = worker.create("lus-tests/h1/worker/ordering.lus")
  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end
  t:assert_equal(#messages, 10, "should receive 10 messages")
  for i = 1, 10 do
    t:assert_equal(messages[i], i, "message " .. tostring(i) .. " should be in order")
  end
end)

t:describe("multiple workers")

t:it("runs multiple workers concurrently", function()
  local w1 = worker.create("lus-tests/h1/worker/counter.lus")
  local w2 = worker.create("lus-tests/h1/worker/counter.lus")

  local msgs1 = {}
  local msgs2 = {}

  while true do
    local msg = worker.receive(w1)
    if msg == nil then break end
    table.insert(msgs1, msg)
  end
  while true do
    local msg = worker.receive(w2)
    if msg == nil then break end
    table.insert(msgs2, msg)
  end

  t:assert_equal(#msgs1, 5, "worker 1 should send 5 messages")
  t:assert_equal(#msgs2, 5, "worker 2 should send 5 messages")
end)

t:describe("worker lifecycle")

t:it("worker becomes dead after completion", function()
  local w = worker.create("lus-tests/h1/worker/counter.lus")
  -- Drain all messages
  while worker.receive(w) ~= nil do end
  local status = worker.status(w)
  t:assert_equal(status, "dead", "worker should be dead after completion")
end)

t:describe("error handling")

t:it("propagates worker errors via receive", function()
  local w = worker.create("lus-tests/h1/worker/error.lus")

  -- Worker should error
  local err, result = catch worker.receive(w)

  -- Either we get an error or nil (worker died before we could receive)
  t:assert_true(not err or result == nil,
    "should get error or nil when worker errors")
end)

t:it("error worker becomes dead", function()
  local w = worker.create("lus-tests/h1/worker/error.lus")
  -- Give worker time to error, then drain
  catch worker.receive(w)
  local status = worker.status(w)
  t:assert_equal(status, "dead", "errored worker should be dead")
end)

t:it("handles string messages with special characters", function()
  local w = worker.create("lus-tests/h1/worker/processor.lus")

  worker.send(w, "hello\0world")
  worker.send(w, "line1\nline2")
  worker.send(w, "\t\r\n")
  worker.send(w, "STOP")

  local messages = {}
  while true do
    local msg = worker.receive(w)
    if msg == nil then break end
    table.insert(messages, msg)
  end

  t:assert_equal(#messages, 4, "should receive 4 responses")
  t:assert_equal(messages[4], "STOPPED", "last message should be STOPPED")
end)

t:finish()
