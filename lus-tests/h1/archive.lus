global print, require, assert, type, string, table, vector, pledge, tostring

pledge("load", "fs:read=./lus-tests/*", "seal")

local framework = require("lus-tests.framework")
local tests = framework.new("archive")

local sample = "Hello, World! This is a test of the compression library. " ..
               "We need enough data to make compression meaningful. " ..
               string.rep("abcdefghijklmnopqrstuvwxyz ", 20)

local empty = ""

-- ===================================================================
-- Gzip
-- ===================================================================

tests:describe("vector.archive.gzip")

tests:it("gzip roundtrip string", function()
    local compressed = vector.archive.gzip.compress(sample)
    assert(type(compressed) == "string", "compress should return string")
    assert(#compressed < #sample, "compressed should be smaller")
    local decompressed = vector.archive.gzip.decompress(compressed)
    assert(decompressed == sample, "roundtrip should preserve data")
end)

tests:it("gzip roundtrip vector", function()
    local v = vector.create(#sample, true)
    vector.pack(v, 0, "c" .. #sample, sample)
    local compressed = vector.archive.gzip.compress(v)
    assert(type(compressed) == "vector", "compress should return vector")
    local decompressed = vector.archive.gzip.decompress(compressed)
    assert(type(decompressed) == "vector", "decompress should return vector")
    assert(#decompressed == #sample, "roundtrip should preserve length")
    local result = vector.unpack(decompressed, 0, "c" .. #sample)
    assert(result == sample, "roundtrip should preserve data")
end)

tests:it("gzip empty data", function()
    local compressed = vector.archive.gzip.compress(empty)
    local decompressed = vector.archive.gzip.decompress(compressed)
    assert(decompressed == empty, "empty roundtrip should work")
end)

tests:it("gzip compression levels", function()
    local c0 = vector.archive.gzip.compress(sample, 0)
    local c9 = vector.archive.gzip.compress(sample, 9)
    -- Both should decompress correctly
    assert(vector.archive.gzip.decompress(c0) == sample)
    assert(vector.archive.gzip.decompress(c9) == sample)
    -- Level 9 should be at least as small as level 0
    assert(#c9 <= #c0, "higher level should compress better or equal")
end)

tests:it("gzip invalid data", function()
    tests:assert_throws(function()
        vector.archive.gzip.decompress("not valid gzip data!!")
    end)
end)

tests:it("gzip invalid level", function()
    tests:assert_throws(function()
        vector.archive.gzip.compress(sample, 10)
    end)
end)

