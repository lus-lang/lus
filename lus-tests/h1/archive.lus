        vector.archive.lz4.decompress("not valid lz4 data!!")
    end)
end)

-- ===================================================================
-- Cross-format checks
-- ===================================================================

tests:describe("cross-format")

tests:it("different formats produce different output", function()
    local gz = vector.archive.gzip.compress(sample)
    local df = vector.archive.deflate.compress(sample)
    local zs = vector.archive.zstd.compress(sample)
    local br = vector.archive.brotli.compress(sample)
    local lz = vector.archive.lz4.compress(sample)
    -- All should be different from each other (different headers/formats)
    assert(gz ~= df, "gzip and deflate should differ")
    assert(gz ~= zs, "gzip and zstd should differ")
    assert(zs ~= br, "zstd and brotli should differ")
    assert(br ~= lz, "brotli and lz4 should differ")
end)

tests:it("type argument validation", function()
    tests:assert_throws(function()
        vector.archive.gzip.compress(true)
    end)
end)

tests:finish()
