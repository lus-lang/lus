-- Table indexing with string variables (OP_GETTABLE with short-string keys)

global print, os, string

local t = {alpha = 1, beta = 2, gamma = 3, delta = 4}
local keys = {"alpha", "beta", "gamma", "delta"}
local N = 60000000
local s = 0

local t0 = os.clock()
for i = 1, N do
    s = s + t[keys[(i & 3) + 1]]
end
local elapsed = os.clock() - t0

print(string.format("TIME %.4f", elapsed))
print("CHECK " .. s)
