-- pairs iteration benchmark (OP_TFORCALL with the pairs/next builtin)
-- Mixed table: 500 array-part entries + 500 hash-part entries.

global print, os, string, pairs

local t = {}
for i = 1, 500 do
    t[i] = i
end
for i = 1, 500 do
    t["key_" .. i] = i
end

local OUTER = 30000
local s = 0

local t0 = os.clock()
for _ = 1, OUTER do
    for _, v in pairs(t) do
        s = s + v
    end
end
local elapsed = os.clock() - t0

print(string.format("TIME %.4f", elapsed))
print("CHECK " .. s)
